# ─────────────────────────────────────────────────────────────────────────────
# Navora — environment configuration
# Copy to `.env` and fill in. Every key is optional; agents that lack a key
# degrade gracefully. Minimum useful set: OPENCAGE_API_KEY + GOOGLE_API_KEY.
# ─────────────────────────────────────────────────────────────────────────────

# Google Gemini — reasoning (goal parsing, itinerary narrative, day planning)
# Free key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# OpenCage — geocoding + country annotations (currency, timezone, flag).
# Powers the Destination & Logistics agents. Free tier: 2,500 req/day.
# Key: https://opencagedata.com/
OPENCAGE_API_KEY=

# AviationStack — real flight schedules / airlines on a route (no fares;
# prices are estimated). Free tier: 100 req/month.
# Key: https://aviationstack.com/
AVIATIONSTACK_API_KEY=

# GeoDB Cities — city search/autocomplete, population, region.
# Optional: if blank, falls back to the free no-key GeoDB service.
# RapidAPI key: https://rapidapi.com/wirefreethought/api/geodb-cities
GEODB_API_KEY=

# Weather (Open-Meteo) and Hotels/Activities/Maps (OpenStreetMap) need NO key.

# ---- behavior ----
# Force offline mode (skip Gemini even if a key is set): true/false
DEMO_MODE=false
# Max critic-triggered replans before finalizing (fail-safe)
MAX_REVISIONS=2
