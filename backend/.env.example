# Google Gemini API key — get one free at https://aistudio.google.com/app/apikey
# Leave blank to run in offline DEMO mode (rule-based orchestrator + mock data).
GOOGLE_API_KEY=

# Gemini model to use for agent reasoning.
GEMINI_MODEL=gemini-2.0-flash

# Force offline mode even if a key is set (true/false).
DEMO_MODE=false

# Max number of critic-triggered replans before finalizing (fail-safe).
MAX_REVISIONS=2
